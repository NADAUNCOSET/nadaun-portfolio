# NADAUN 사이트 .gitignore — 공통 baseline (BACKUP_RULE.md 참조)

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Vercel
.vercel

# 작업 백업 (BACKUP_RULE.md — git 이력 + 로컬 backups/ 2중 보호)
backups/*
!backups/.gitkeep
_archive/

# ─── 사이트별 (대용량 이미지 — Cloudflare R2로 이관 예정) ───
images/
스크린샷/
api/
*.jpg
*.JPG
*.jpeg
*.JPEG
*.png
*.PNG
*.heic
*.HEIC
*.tif
*.tiff

# 파비콘은 예외 (사이트에서 필요)
!favicon.ico
!favicon-*.png
!apple-touch-icon.png
